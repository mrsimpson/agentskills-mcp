{
  "name": "@codemcp/skills",
  "version": "2.1.1",
  "description": "Command-line interface for Agent Skills management",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "ade-skills": "./dist/cli.js"
  },
  "exports": {
    "./api": "./dist/api.js"
  },
  "files": [
    "dist",
    "README.md",
    "ThirdPartyNoticeText.txt"
  ],
  "scripts": {
    "build": "tsup",
    "build:obuild": "obuild",
    "generate-licenses": "node --loader tsx scripts/generate-licenses.ts",
    "dev": "node --loader tsx src/cli.ts",
    "exec:test": "node --loader tsx scripts/execute-tests.ts",
    "prepublishOnly": "npm run build",
    "format": "prettier --write 'src/**/*.ts' 'scripts/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'scripts/**/*.ts'",
    "prepare": "husky",
    "test": "vitest",
    "type-check": "tsc --noEmit"
  },
  "lint-staged": {
    "src/**/*.ts": "prettier --write",
    "scripts/**/*.ts": "prettier --write",
    "tests/**/*.ts": "prettier --write"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "pacote": "21.3.1",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@clack/prompts": "^0.11.0",
    "@codemcp/skills-core": "workspace:*",
    "@types/node": "^22.10.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "obuild": "^0.4.22",
    "picocolors": "^1.1.1",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17",
    "xdg-basedir": "^5.1.0"
  },
  "keywords": [
    "agentskills",
    "cli",
    "skills-management"
  ],
  "author": "Oliver Jägle <github@beimir.net>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
