{
  "name": "@codemcp/skills-monorepo",
  "version": "2.1.1",
  "private": true,
  "description": "MCP server that exposes Claude Code Agent Skills to any MCP-compatible agent",
  "authors": [
    "Oliver Jägle <github@beimir.net>"
  ],
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agentskills",
    "agent-skills",
    "claude-code",
    "ai",
    "assistant",
    "skills",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mrsimpson/agentskills-mcp"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean:build",
    "dev": "turbo run dev",
    "prepublishOnly": "npm run build",
    "test": "turbo run --parallel test",
    "test:watch": "turbo run --parallel test:watch",
    "lint:all": "turbo run --parallel lint",
    "lint:fix:all": "turbo run --parallel lint:fix",
    "format:check:all": "turbo run --parallel format",
    "format:all": "turbo run --parallel format:fix",
    "typecheck:all": "turbo run --parallel typecheck",
    "prepare": "husky",
    "clean:build": "turbo run clean:build",
    "docs:dev": "cp packages/core/src/skill-frontmatter.schema.json docs/public/ && vitepress dev docs",
    "docs:build": "mkdir -p docs/public && cp packages/core/src/skill-frontmatter.schema.json docs/public/ && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@braintree/sanitize-url": "7.1.1",
    "@eslint/js": "9.18.0",
    "@swc/core": "^1.10.9",
    "@tsconfig/node22": "22.0.0",
    "@tsconfig/strictest": "2.0.5",
    "@types/eslint-config-prettier": "6.11.3",
    "@types/node": "^22.10.7",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "@vitest/coverage-v8": "^3.0.3",
    "cytoscape": "3.31.0",
    "cytoscape-cose-bilkent": "4.1.0",
    "dayjs": "1.11.13",
    "debug": "4.4.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.1",
    "nodemon": "^3.1.9",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "8.21.0",
    "vitepress": "1.6.2",
    "vitepress-plugin-mermaid": "2.0.17",
    "vitest": "^3.0.3"
  },
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@codemcp/skills-core": "workspace:*",
    "@codemcp/skills-server": "workspace:*"
  },
  "agentskills": {
    "commit": "github:mrsimpson/skills-coding/commit",
    "tdd": "github:mrsimpson/skills-coding/tdd-with-agents",
    "knowledge": "github:mrsimpson/agentic-knowledge-mcp/skill",
    "responsible-vibe": "@codemcp/workflows::path:/skill"
  }
}
